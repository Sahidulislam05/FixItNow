model User {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String
  phone        String?
  role         Role         @default(CUSTOMER)
  activeStatus ActiveStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  technicianProfile TechnicianProfile?
  availabilities    TechnicianAvailability[]
  services          Service[]

  bookingsAsCustomer   Booking[] @relation("CustomerBookings")
  bookingsAsTechnician Booking[] @relation("TechnicianBookings")

  reviewsAsCustomer   Review[] @relation("CustomerReviews")
  reviewsAsTechnician Review[] @relation("TechnicianReviews")

  @@map("users")
}
